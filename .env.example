# Satellite fire validation system - environment variables
# Prefix: SAT_

# Confidence thresholds
SAT_THRESHOLD_TRUE_FIRE=0.75
SAT_THRESHOLD_FALSE_POSITIVE=0.35
SAT_INITIAL_CONFIDENCE=0.5

# Confidence weights
SAT_BETA_ENV=0.2

# Coordinate correction
SAT_CORRECTION_RADIUS_M=500.0
SAT_CORRECTION_STEP_M=50.0

# Data directories (local GeoTIFF)
SAT_WORLDCOVER_DIR=data/worldcover
